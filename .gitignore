# ---- Environment ----
.env
.env.*
!.env.example

# ---- Node / Frontend ----
node_modules/
dist/
dist-ssr/
.vite/
*.local
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ---- Python / Backend ----
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
.pytest_cache/
.mypy_cache/
.ruff_cache/
*.egg-info/
.coverage
htmlcov/

# ---- Alembic ----
# Keep versions tracked, ignore local scratch
backend/alembic/versions/*.pyc

# ---- Docker volumes (never commit volume data) ----
postgres_data/
redis_data/
uploads/
whiteboard_snapshots/

# ---- SSL / Secrets ----
nginx/ssl/*
!nginx/ssl/.gitkeep

# ---- Editors / OS ----
.vscode/
.idea/
*.swp
*.swo
.DS_Store
Thumbs.db
desktop.ini

# ---- Logs ----
*.log
logs/

# ---- Build / Cache ----
.cache/
.turbo/

# ---- TypeScript incremental build outputs ----
# `tsc -b` (used by `npm run build`) compiles the Vite/Tailwind config
# files in tsconfig.node.json with composite=true, which emits .js/.d.ts
# siblings + a .tsbuildinfo cache. None of these are runtime artefacts —
# Vite reads the original .ts configs directly — so we keep them out of
# the repo.
*.tsbuildinfo
frontend/vite.config.js
frontend/vite.config.d.ts
frontend/tailwind.config.js
frontend/tailwind.config.d.ts

# ---- Generated PWA icons (re-rendered from public/promptly-icon.svg
#      every build via scripts/generate-pwa-icons.mjs) ----
frontend/public/pwa-192.png
frontend/public/pwa-512.png
frontend/public/pwa-maskable-512.png
frontend/public/apple-touch-icon.png
frontend/public/favicon.png
frontend/public/pwa-icons.generated

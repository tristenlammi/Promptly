{
  "version": "0.0.1",
  "configurations": [
    {
      "name": "promptly",
      "runtimeExecutable": "docker",
      "runtimeArgs": ["compose", "up", "-d"],
      "port": 8091,
      "autoPort": false
    },
    {
      "name": "promptly-vite",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "frontend", "run", "dev", "--", "--config", "vite.preview-claude.config.ts"],
      "port": 5199,
      "autoPort": false
    },
    {
      "name": "promptly-vite-alt",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["--prefix", "frontend", "run", "dev", "--", "--config", "vite.preview-claude-alt.config.ts"],
      "port": 5201,
      "autoPort": false
    }
  ]
}

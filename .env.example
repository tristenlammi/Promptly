# ============================================================
# Promptly — Environment Configuration
# Copy this file to `.env` and fill in the values before
# running `docker compose up`.
# ============================================================

# ---- App ----
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
DOMAIN=localhost

# Host ports the nginx front-door binds to. Defaults are 8087 / 8488 —
# deliberately picked outside the well-known cluster so they don't
# collide with the Unraid web UI, Portainer, the *arr stack,
# qBittorrent, etc. Override here if 8087/8488 also clash on your box.
NGINX_HTTP_PORT=8087
NGINX_HTTPS_PORT=8488

# Legacy single-user flag. Leave `false` for the normal multi-user login
# flow. Setting it to `true` bypasses JWT entirely and returns a fixed local
# user for every request — only useful for quick personal test setups.
SINGLE_USER_MODE=false

# No admin credentials live in this file. The first time Promptly boots
# against an empty database, open the web UI and the setup wizard will
# walk you through creating the initial admin account.

# ---- Database ----
POSTGRES_PASSWORD=change-me-strong-password

# ---- SearXNG ----
# Generate with: openssl rand -hex 32
SEARXNG_SECRET=change-me-generate-with-openssl-rand-hex-32

# ---- Default model provider keys (optional) ----
# Admins can also add and manage providers through the Models tab in the
# admin UI. These env values just seed the bootstrap providers so the
# stack works out of the box without clicking through the admin panel.
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- Optional search providers ----
BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=

# ---- Search config ----
# searxng | brave | tavily
DEFAULT_SEARCH_PROVIDER=searxng
SEARCH_RESULT_COUNT=5
SEARCH_CONCURRENT_REQUESTS=3

# ---- Local LLM (Ollama) ----
# The bundled Ollama runtime handles knowledge-library embeddings out of
# the box on CPU. For chat-model inference (Phase 2) you'll usually want
# a GPU — set COMPOSE_PROFILES=gpu below and the ``ollama-gpu`` service
# takes over, reserving the host's NVIDIA GPUs via the NVIDIA Container
# Toolkit.
#
# Before switching to gpu, stop the CPU variant so they don't fight over
# the 11435 host port:
#
#   docker compose stop ollama
#   COMPOSE_PROFILES=gpu docker compose up -d
#
# Non-NVIDIA hosts should leave this blank — upstream Ollama falls back
# to CPU cleanly. Apple Silicon Metal acceleration requires running
# Ollama natively on the host rather than in Docker.
# COMPOSE_PROFILES=gpu

# Port the bundled Ollama publishes on the host. Default is 11435 (one
# above the upstream default) so a host-side Ollama install you use for
# other tooling can keep running on 11434 undisturbed.
OLLAMA_HOST_PORT=11435

# Embedding model pulled automatically on first boot. Kept small on
# purpose — heavier chat models are pulled via the Local Models UI.
OLLAMA_DEFAULT_EMBEDDING_MODEL=nomic-embed-text

# ---- Web Push (PWA notifications) ----
# Generate one keypair per deployment with:
#     python backend/scripts/generate_vapid_keys.py
# Paste both PEM blocks below as single-line values (escape newlines as \n
# or wrap the PEM in double quotes depending on your shell). Leaving
# these blank disables push — the Notifications panel gracefully hides
# the Subscribe button.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
# Contact the push service can reach out to if something goes wrong
# with your pushes (abuse reports, rate limits, etc.). mailto: or https:
VAPID_CONTACT=mailto:admin@example.com

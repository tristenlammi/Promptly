# ============================================================
# Promptly — environment configuration
#
# You need this file before `docker compose up -d` will boot —
# the backend refuses to start on the placeholder secrets below
# (see app.config.validate_boot_safety). The install script creates
# it and seeds strong values automatically, so you never edit this
# by hand in the normal case:
#   ./install.sh   (Linux/macOS)   |   .\install.ps1   (Windows)
#
# Setting up without the installer (e.g. Unraid Compose Manager with
# no shell to run a script): copy this file to `.env` next to
# docker-compose.yml and replace the three `change-me` values below
# with the `openssl rand -hex N` command shown above each one.
#
# Everything else — admin account, public domain, model providers,
# search providers, push notifications — is configured through the
# first-run wizard and the Admin panel inside Promptly itself.
# ============================================================

# ---- App secret (required — JWT signing + at-rest encryption key) ----
# Generate manually with: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# ---- Database (else defaults to `promptly` — fine for a localhost box) ----
POSTGRES_PASSWORD=change-me-strong-password

# ---- SearXNG (else a localhost default) ----
# Generate manually with: openssl rand -hex 32
SEARXNG_SECRET=change-me-generate-with-openssl-rand-hex-32


# ============================================================
# Optional — port bindings + advanced toggles
# ============================================================

# ---- Optional bundled services (compose profiles) ----
# Which optional containers `docker compose up -d` starts. Managed by
# install.sh / install.ps1 (--no-ollama / --no-search / --minimal), or
# edit by hand. Tokens:
#   ollama — bundled local-model runtime (embeddings + local chat models)
#   search — bundled SearXNG web search
# Keep SEARXNG_ENABLED in sync with the `search` token — it gates the
# backend health probe and the default search-provider provisioning.
COMPOSE_PROFILES=ollama,search
SEARXNG_ENABLED=true

# ---- External Ollama (only relevant without the `ollama` token) ----
# Point the backend at an Ollama you already run on the host:
# OLLAMA_URL=http://host.docker.internal:11434

# ---- Host ports the nginx front-door binds to ----
# Defaults are 8087 / 8488 — deliberately picked outside the
# well-known cluster so they don't collide with the Unraid web UI,
# Portainer, the *arr stack, qBittorrent, etc. Override here if
# 8087/8488 also clash on your box.
NGINX_HTTP_PORT=8087
NGINX_HTTPS_PORT=8488

# ---- Bundled Ollama host port ----
# 11435 (one above upstream's 11434) so a host-side Ollama install
# you use for other tooling can keep running undisturbed.
OLLAMA_HOST_PORT=11435

# ---- GPU acceleration for the bundled Ollama ----
# To switch the bundled Ollama container to the GPU variant (NVIDIA
# only — needs the NVIDIA Container Toolkit on the host), swap the
# `ollama` token for `gpu` in COMPOSE_PROFILES above, e.g.:
#
#   COMPOSE_PROFILES=gpu,search
#
# then: docker compose stop ollama && docker compose up -d
# (Don't run both — the CPU and GPU variants fight over port 11435.)
# Apple Silicon Metal acceleration requires running Ollama
# natively on the host rather than in Docker (see OLLAMA_URL above).

# ---- Legacy single-user flag ----
# Leave `false` for the normal multi-user login flow. Setting it
# to `true` bypasses JWT entirely and returns a fixed local user
# for every request — only useful for quick personal test setups.
SINGLE_USER_MODE=false

# ============================================================
# Promptly — Environment Configuration
# Copy this file to `.env` and fill in the values before
# running `docker compose up`.
# ============================================================

# ---- App ----
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32
DOMAIN=localhost

# Override these if the standard HTTP/HTTPS ports are already in use on the host.
NGINX_HTTP_PORT=80
NGINX_HTTPS_PORT=443

# Legacy single-user flag. Leave `false` for the normal multi-user login
# flow. Setting it to `true` bypasses JWT entirely and returns a fixed local
# user for every request — only useful for quick personal test setups.
SINGLE_USER_MODE=false

# No admin credentials live in this file. The first time Promptly boots
# against an empty database, open the web UI and the setup wizard will
# walk you through creating the initial admin account.

# ---- Database ----
POSTGRES_PASSWORD=change-me-strong-password

# ---- SearXNG ----
# Generate with: openssl rand -hex 32
SEARXNG_SECRET=change-me-generate-with-openssl-rand-hex-32

# ---- Default model provider keys (optional) ----
# Admins can also add and manage providers through the Models tab in the
# admin UI. These env values just seed the bootstrap providers so the
# stack works out of the box without clicking through the admin panel.
OPENROUTER_API_KEY=
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# ---- Optional search providers ----
BRAVE_SEARCH_API_KEY=
TAVILY_API_KEY=

# ---- Search config ----
# searxng | brave | tavily
DEFAULT_SEARCH_PROVIDER=searxng
SEARCH_RESULT_COUNT=5
SEARCH_CONCURRENT_REQUESTS=3

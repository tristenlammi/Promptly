# ============================================================
# Promptly — environment configuration
#
# You need this file before `docker compose up -d` will boot —
# the backend refuses to start on the placeholder secrets below
# (see app.config.validate_boot_safety). The install script creates
# it and seeds strong values automatically, so you never edit this
# by hand in the normal case:
#   ./install.sh   (Linux/macOS)   |   .\install.ps1   (Windows)
#
# Setting up without the installer (e.g. Unraid Compose Manager with
# no shell to run a script): copy this file to `.env` next to
# docker-compose.yml and replace the three `change-me` values below
# with the `openssl rand -hex N` command shown above each one.
#
# Everything else — admin account, public domain, model providers,
# search providers, push notifications — is configured through the
# first-run wizard and the Admin panel inside Promptly itself.
# ============================================================

# ---- App secret (required — JWT signing + at-rest encryption key) ----
# Generate manually with: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# ---- Database (else defaults to `promptly` — fine for a localhost box) ----
POSTGRES_PASSWORD=change-me-strong-password

# ---- SearXNG (else a localhost default) ----
# Generate manually with: openssl rand -hex 32
SEARXNG_SECRET=change-me-generate-with-openssl-rand-hex-32


# ============================================================
# Optional — port bindings + advanced toggles
# ============================================================

# ---- Optional bundled services (compose profiles) ----
# Which optional containers `docker compose up -d` starts. install.sh /
# install.ps1 sets this automatically (--with-ollama / --no-search), or
# edit by hand. Tokens:
#   search — bundled SearXNG web search
#   ollama — local-model runtime, CPU build (universal)   ] only ONE, and
#   gpu    — local-model runtime, NVIDIA CUDA build        ] only via
#   rocm   — local-model runtime, AMD ROCm build           ] --with-ollama
# By default NO Ollama container is bundled — the stack talks to cloud
# providers (bring your API keys) and/or a native host Ollama (see
# OLLAMA_URL below). Keep SEARXNG_ENABLED in sync with the `search`
# token — it gates the health probe and search-provider provisioning.
COMPOSE_PROFILES=search
SEARXNG_ENABLED=true

# ---- Host Ollama ----
# When no Ollama container is bundled, point the backend at a native
# Ollama running on the host. install.sh sets this automatically if it
# detects one; the backend reaches it via the host.docker.internal alias
# (wired in compose for Linux/Unraid, not just Docker Desktop). A host
# Ollama must listen beyond loopback for containers to reach it on Linux
# (start it with OLLAMA_HOST=0.0.0.0).
# OLLAMA_URL=http://host.docker.internal:11434

# ---- Host ports the nginx front-door binds to ----
# Defaults are 8087 / 8488 — deliberately picked outside the
# well-known cluster so they don't collide with the Unraid web UI,
# Portainer, the *arr stack, qBittorrent, etc. Override here if
# 8087/8488 also clash on your box.
NGINX_HTTP_PORT=8087
NGINX_HTTPS_PORT=8488

# ---- Bundled Ollama host port ----
# 11435 (one above upstream's 11434) so a host-side Ollama install
# you use for other tooling can keep running undisturbed.
OLLAMA_HOST_PORT=11435

# ---- GPU acceleration for the bundled Ollama ----
# install.sh auto-detects this: NVIDIA (nvidia-smi + Docker GPU
# support) -> `gpu` token, AMD (/dev/kfd) -> `rocm` token, otherwise
# the CPU `ollama` token. To change it manually, swap the token in
# COMPOSE_PROFILES above and run:
#
#   docker compose up -d --remove-orphans
#
# NVIDIA on Linux needs the NVIDIA Container Toolkit; Windows needs
# Docker Desktop's WSL2 backend. Apple Silicon can't be accelerated
# inside Docker — run Ollama natively on the host instead (install.sh
# detects it and wires OLLAMA_URL automatically; see OLLAMA_URL above).
#
# AMD (rocm) on Linux/Unraid: the GPU shows up via /dev/kfd + /dev/dri
# (no toolkit needed). If `docker exec Promptly-Ollama-ROCm ollama ps`
# reports 100% CPU on a GPU box, your card needs an HSA GFX override —
# uncomment the matching line in the ollama-rocm service in
# docker-compose.yml (values for common cards are listed there).

# ---- Legacy single-user flag ----
# Leave `false` for the normal multi-user login flow. Setting it
# to `true` bypasses JWT entirely and returns a fixed local user
# for every request — only useful for quick personal test setups.
SINGLE_USER_MODE=false

# ============================================================
# Promptly — environment configuration
#
# You do NOT need this file to get started: `docker compose up -d`
# works with no .env at all. On first boot the stack generates a
# strong random SECRET_KEY (kept in the `promptly-secrets` Docker
# volume) and uses safe localhost defaults for the internal
# Postgres/SearXNG secrets.
#
# Create this file (and set the three secrets below) when you want
# to pin your own values — e.g. BEFORE exposing Promptly on a
# public domain, where the boot guard refuses default datastore
# creds. The install script does it for you:
#   ./install.sh   (Linux/macOS)   |   .\install.ps1   (Windows)
#
# Anything set here OVERRIDES the auto-generated defaults.
#
# Everything else — admin account, public domain, model providers,
# search providers, push notifications — is configured through the
# first-run wizard and the Admin panel inside Promptly itself.
# ============================================================

# ---- App secret (else auto-generated into the promptly-secrets volume) ----
# Generate manually with: openssl rand -hex 32
SECRET_KEY=change-me-generate-with-openssl-rand-hex-32

# ---- Database (else defaults to `promptly` — fine for a localhost box) ----
POSTGRES_PASSWORD=change-me-strong-password

# ---- SearXNG (else a localhost default) ----
# Generate manually with: openssl rand -hex 32
SEARXNG_SECRET=change-me-generate-with-openssl-rand-hex-32


# ============================================================
# Optional — port bindings + advanced toggles
# ============================================================

# ---- Host ports the nginx front-door binds to ----
# Defaults are 8087 / 8488 — deliberately picked outside the
# well-known cluster so they don't collide with the Unraid web UI,
# Portainer, the *arr stack, qBittorrent, etc. Override here if
# 8087/8488 also clash on your box.
NGINX_HTTP_PORT=8087
NGINX_HTTPS_PORT=8488

# ---- Bundled Ollama host port ----
# 11435 (one above upstream's 11434) so a host-side Ollama install
# you use for other tooling can keep running undisturbed.
OLLAMA_HOST_PORT=11435

# ---- GPU acceleration for the bundled Ollama ----
# Uncomment to switch the bundled Ollama container to the GPU
# variant (NVIDIA only — needs the NVIDIA Container Toolkit on the
# host). Stop the CPU variant first so they don't fight over
# 11435:
#
#   docker compose stop ollama
#   COMPOSE_PROFILES=gpu docker compose up -d
#
# Apple Silicon Metal acceleration requires running Ollama
# natively on the host rather than in Docker.
# COMPOSE_PROFILES=gpu

# ---- Legacy single-user flag ----
# Leave `false` for the normal multi-user login flow. Setting it
# to `true` bypasses JWT entirely and returns a fixed local user
# for every request — only useful for quick personal test setups.
SINGLE_USER_MODE=false
